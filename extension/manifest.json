{
  "manifest_version": 3,
  "name": "LeetCode Tracker",
  "version": "0.1.3",
  "description": "Capture leetcode.cn submissions and send them to the local leetcode-tracker bridge.",
  "permissions": ["storage", "alarms", "scripting", "tabs"],
  "host_permissions": [
    "https://leetcode.cn/*",
    "http://127.0.0.1:8763/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://leetcode.cn/*"],
      "js": ["inject.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://leetcode.cn/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["inject.js"],
      "matches": ["https://leetcode.cn/*"]
    }
  ],
  "action": {
    "default_title": "LeetCode Tracker",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
